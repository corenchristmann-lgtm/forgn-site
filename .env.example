# Forgn — variables d'environnement
# Copier en .env.local et renseigner les valeurs.

# Microsoft Clarity — analyse comportementale (heatmaps + session recordings)
# Créer projet sur https://clarity.microsoft.com puis récupérer le Project ID
NEXT_PUBLIC_CLARITY_ID=

# Sentry — error tracking (optionnel, à activer plus tard)
# Lancer : npx @sentry/wizard@latest -i nextjs
# Renseignera automatiquement les variables ci-dessous.
# SENTRY_DSN=
# NEXT_PUBLIC_SENTRY_DSN=
# SENTRY_AUTH_TOKEN=

# Vercel Analytics + Speed Insights : aucune variable nécessaire,
# activation automatique sur déploiement Vercel.
